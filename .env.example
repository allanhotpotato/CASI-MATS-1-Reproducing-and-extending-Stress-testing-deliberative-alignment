# Copy this file to .env and fill in your actual keys.
# Never commit your .env file.

# Moltbook API (required for all environment runs)
MOLTBOOK_API_KEY=your_moltbook_api_key_here
MOLTBOOK_BASE_URL=https://api.moltbook.com   # override if using a local mock

# DeepSeek API (required for deepseek-r1 model)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Qwen / Together AI (required for qwen-qwq-32b model)
QWEN_API_KEY=your_together_ai_api_key_here
QWEN_BASE_URL=https://api.together.xyz/v1

# LLM judge (used by evaluation/llm_judge.py — defaults to Anthropic)
JUDGE_API_KEY=your_anthropic_api_key_here
JUDGE_MODEL=claude-sonnet-4-6
